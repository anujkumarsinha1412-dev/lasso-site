---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}
const { post } = Astro.props;
const { Content } = await render(post);
---
<BlogLayout title={post.data.title} description={post.data.description} date={post.data.date.toISOString()} isPost={true} url={new URL(`/blog/${post.id}/`, Astro.site).href}>
  <span class="kicker">AgenQuest Blog</span>
  <h1>{post.data.title}</h1>
  <p class="meta">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })} · AgenQuest</p>
  <article>
    <Content />
  </article>
  <div class="cta-box">
    <h2>See what AI says about your brand.</h2>
    <p>Free audit: real consumer prompts across ChatGPT, Claude, Perplexity &amp; Google AI Overviews — with screenshots and plain-language findings.</p>
    <a href="/#audit" class="btn-accent" style="text-decoration:none;">Get your free audit</a>
  </div>
</BlogLayout>
